{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "fs:default",
    "dialog:default",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$DOWNLOAD/**/*" },
        { "path": "$DOWNLOAD" },
        { "path": "$DESKTOP/**/*" },
        { "path": "$DOCUMENT/**/*" },
        { "path": "$DATA/**/*" },
        { "path": "$HOME/**/*" },
        { "path": "$APPDATA/**/*" },
        { "path": "$APPLOCALDATA/**/*" },
        { "path": "$LOCALDATA/**/*" },
        { "path": "$PICTURE/**/*" },
        { "path": "$VIDEO/**/*" },
        { "path": "$PUBLIC/**/*" },
        { "path": "$EXE/**/*" },
        { "path": "$FONT/**/*" },
        { "path": "$TEMPLATE/**/*" },
        { "path": "$CACHE/**/*" },
        { "path": "$LOG/**/*" },
        { "path": "$TEMP/**/*" }
      ]
    },
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "https://*.donmai.us/*"
        },
        {
          "url": "https://danbooru.donmai.us/*"
        },
        {
          "url": "https://gelbooru.com/*"
        },
        {
          "url": "https://*.gelbooru.com/*"
        },
        {
          "url": "https://safebooru.org/*"
        },
        {
          "url": "https://konachan.com/*"
        },
        {
          "url": "https://yande.re/*"
        }
      ]
    }
  ]
}
